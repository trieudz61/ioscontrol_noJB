<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleExecutable</key>
    <string>ICToastService</string>
    <key>CFBundleIdentifier</key>
    <string>com.trieu.ioscontrol.toastservice</string>
    <key>CFBundleName</key>
    <string>ICToastService</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>LSRequiresIPhoneOS</key>
    <true/>
    <key>NSPrincipalClass</key>
    <string>UIApplication</string>

    <!-- Hide from SpringBoard home screen and app switcher (like XXTUIService) -->
    <key>SBAppTags</key>
    <array>
        <string>hidden</string>
    </array>

    <!-- Allow overlay on lock screen -->
    <key>UIApplicationShowsViewsWhileLocked</key>
    <true/>

    <!-- Allow system-level window overlay (private key — works under TrollStore) -->
    <key>UIApplicationSystemWindowsSecureKey</key>
    <true/>

    <!-- Keep alive in background -->
    <key>UIBackgroundModes</key>
    <array>
        <string>audio</string>
        <string>continuous</string>
        <string>voip</string>
    </array>

    <!-- No status bar, no visible UI -->
    <key>UIStatusBarHidden</key>
    <true/>
    <key>UIApplicationSceneManifest</key>
    <dict>
        <key>UIApplicationSupportsMultipleScenes</key>
        <false/>
    </dict>
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsArbitraryLoads</key>
        <true/>
    </dict>
</dict>
</plist>
