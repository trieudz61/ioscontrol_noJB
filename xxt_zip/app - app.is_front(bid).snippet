local group, name

group = 'App'
name = 'app.is_front(bid)'

return {
	name = string.format('%s - %s', group, name),
	description = "获取前台应用的 Bundle Identifier 并判断",
	arguments = {
		{type = 'app'},
	},
	generator = function(bid)
		return string.format('(app.front_bid() == %q)', bid)
	end,
}