local group, name

group = 'App'
name = 'app.data_path(bid)'

return {
	name = string.format('%s - %s', group, name),
	description = "获取 App 的应用存档路径",
	arguments = {
		{type = 'app'},
	},
	generator = function(bid)
		return string.format('app.data_path(%q)', bid)
	end,
}