local group, name

group = 'App'
name = 'app.is_running(bid)'

return {
	name = string.format('%s - %s', group, name),
	description = "检测应用程序是否正在运行",
	arguments = {
		{type = 'app'},
	},
	generator = function(bid)
		return string.format('app.is_running(%q)', bid)
	end,
}