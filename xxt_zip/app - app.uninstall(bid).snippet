local group, name

group = 'App'
name = 'app.uninstall(bid)'

return {
	name = string.format('%s - %s', group, name),
	description = "卸载应用程序",
	arguments = {
		{type = 'app'},
	},
	generator = function(bid)
		return string.format('app.uninstall(%q)', bid)
	end,
}