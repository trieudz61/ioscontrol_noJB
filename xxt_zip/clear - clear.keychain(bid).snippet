local group, name

group = '清理'
name = 'clear.keychain(bid)'

return {
	name = string.format('%s - %s', group, name),
	description = "清理某个或某组钥匙串信息",
	arguments = {
		{type = 'app'},
	},
	generator = function(bid)
		return string.format('clear.keychain("%%%s%%")', bid)
	end,
}